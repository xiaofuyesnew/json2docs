{
  "name": "@json2docs/core",
  "version": "0.1.0",
  "description": "JSON2Docs 核心转换引擎",
  "main": "dist/index.cjs.js",
  "module": "dist/index.es.js",
  "unpkg": "dist/index.umd.js",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node test.js",
    "test:advanced": "node test-advanced.js",
    "test:performance": "node performance-test.js",
    "test:all": "node test.js && node test-advanced.js && node performance-test.js"
  },
  "devDependencies": {
    "terser": "^5.0.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "docx": "^8.5.0",
    "jspdf": "^3.0.1",
    "jspdf-autotable": "^5.0.2",
    "pdfmake": "^0.2.7"
  },
  "keywords": [
    "json2docs",
    "pdfmake",
    "document-generation",
    "html",
    "pdf",
    "docx"
  ],
  "author": "JSON2Docs Team",
  "license": "MIT"
}